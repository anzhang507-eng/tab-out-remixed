{
  "manifest_version": 3,
  "name": "Tab Out Remixed",
  "version": "1.0.0",
  "description": "Keep tabs on your tabs. New tab page that groups your open tabs by domain with Feishu-only view and open timestamps.",
  "permissions": ["tabs", "activeTab", "storage", "history"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out Remixed",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
